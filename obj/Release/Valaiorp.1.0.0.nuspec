<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>Valaiorp</id>
    <version>1.0.0</version>
    <authors>Jey</authors>
    <license type="expression">Apache-2.0</license>
    <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
    <readme>README.md</readme>
    <description>Valaiorp — production-grade Workflow and Agentic AI Execution Framework for .NET 10. Supports IRPA, AI Workflow, AI Agent, and fully Agentic modes with multi-bot/multi-machine work queues, built-in guardrails, policy enforcement, retry, escalation, and pluggable LLM providers.</description>
    <tags>ai agent agentic llm workflow irpa rpa bot queue framework net10 dotnet</tags>
    <repository type="git" commit="16570d38ca646345c65d06a5a8f778d5534d0d53" />
    <dependencies>
      <group targetFramework="net10.0" />
    </dependencies>
  </metadata>
